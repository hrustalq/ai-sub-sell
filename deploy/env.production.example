# Copy to /opt/ai-sub-sell/shared/.env on the VPS (never commit real secrets).

NODE_ENV=production
PORT=3000

# Persistent SQLite — lives outside the git tree; deploy never deletes this path.
DATABASE_URL="file:/var/lib/ai-sub-sell/data/production.db"

BETTER_AUTH_SECRET="generate-a-long-random-secret-at-least-32-chars"
BETTER_AUTH_URL="https://ai-sub.store"
NEXT_PUBLIC_BETTER_AUTH_URL="https://ai-sub.store"

# SEO (optional — SITE_URL overrides BETTER_AUTH_URL for metadata/sitemap)
# SITE_URL="https://ai-sub.store"
# GOOGLE_SITE_VERIFICATION=""
# YANDEX_VERIFICATION=""

NEXT_PUBLIC_YANDEX_METRIKA_ID=your-id

ADMIN_EMAILS="admin@example.com"
SUPPORT_EMAILS="support@example.com"
CORE_ADMIN_EMAILS="admin@example.com"

# First-time seed (deploy/seed.sh) — create/update the admin login
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-before-seed"
ADMIN_NAME="Администратор"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
# Required when YooKassa online receipts (54-FZ) are enabled
YOOKASSA_RECEIPT_VAT_CODE="1"
YOOKASSA_RECEIPT_PAYMENT_SUBJECT="service"

LEGAL_ENTITY_NAME="ИП …"
LEGAL_FORM="ИП"
LEGAL_INN=""
LEGAL_OGRN=""
LEGAL_ADDRESS=""
LEGAL_EMAIL="legal@ai-sub.store"
# LEGAL_PHONE=""

SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL="no-reply@ai-sub.store"
SMTP_FROM_NAME="ai-sub"

CRON_SECRET="generate-another-random-secret"

# Optional: prefer IPv4 for Node (fixes api.telegram.org timeouts when IPv6 is broken on the VPS).
# Usually set in systemd instead; scripts/load-env.ts applies the same for pnpm telegram:* .
# NODE_OPTIONS="--dns-result-order=ipv4first"

# Logging (stdout → systemd journal → Datadog Agent; view locally with pnpm logs)
# LOG_LEVEL=info
# LOG_PRETTY=false
# LOG_PRISMA_QUERIES=false

# Datadog APM + logs (see docs/DEPLOY.md §7)
# DD_TRACE_ENABLED=true
# DD_SERVICE=ai-sub-sell
# DD_ENV=production
# DD_SITE=datadoghq.com
# DD_API_KEY=your-datadog-api-key
# Set false only when using deploy/setup-datadog.sh Agent (journald) instead of HTTP intake
# DD_LOGS_HTTP=false

TELEGRAM_SELL_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_SUPPORT_USER_IDS=""
# A-Z, a-z, 0-9, _, - only (e.g. openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=""
# Auto-register webhooks on server startup (default: on in production)
# TELEGRAM_AUTO_WEBHOOKS=true
