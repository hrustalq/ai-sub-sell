# SQLite (dev: default path; production: absolute file URL outside the app tree)
# DATABASE_URL="file:/var/lib/ai-sub-sell/data/production.db"

BETTER_AUTH_SECRET="your-better-auth-secret" # at least 32 characters
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app (server)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000 # Same URL for the browser auth client

# SEO (optional — defaults to BETTER_AUTH_URL for sitemap, Open Graph, canonical URLs)
# SITE_URL=https://ai-sub.store
# GOOGLE_SITE_VERIFICATION=
# YANDEX_VERIFICATION=

# Yandex.Metrika (omit locally to disable; set in production)
# NEXT_PUBLIC_YANDEX_METRIKA_ID=your-yandex-metrika-id

# Admin panel (comma-separated emails allowed to access /admin)
ADMIN_EMAILS="admin@example.com"
SUPPORT_EMAILS="support@example.com"
# Core admins can manage RBAC flags for users (comma-separated)
CORE_ADMIN_EMAILS="admin@example.com"

# Dev seed user (prisma/seed.ts) — must match ADMIN_EMAILS
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin12345"
ADMIN_NAME="Администратор"

# Demo buyer + orders (prisma/seed.ts)
SEED_BUYER_EMAIL="buyer@example.com"
SEED_BUYER_PASSWORD="buyer12345"
SEED_BUYER_NAME="Тестовый покупатель"

# Google OAuth — redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth — callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# YooKassa (payment provider — not shown on the public site)
YOOKASSA_SHOP_ID="your-shop-id"
YOOKASSA_SECRET_KEY="your-secret-key"
# Fiscal receipt (54-FZ) — required if online receipts are enabled in YooKassa
# vat_code: 1 = без НДС, 4 = НДС 20%, 11 = НДС 22% (from 2026)
YOOKASSA_RECEIPT_VAT_CODE="1"
# service | intellectual_activity | commodity — see YooKassa receipt docs
YOOKASSA_RECEIPT_PAYMENT_SUBJECT="service"

# Legal / seller requisites (required for /about and legal pages)
LEGAL_ENTITY_NAME="ИП Иванов Иван Иванович"
LEGAL_FORM="ИП"
LEGAL_INN="000000000000"
LEGAL_OGRN="000000000000000"
LEGAL_ADDRESS="123456, г. Москва, ул. Примерная, д. 1"
LEGAL_EMAIL="legal@example.com"
LEGAL_PHONE="+7 (900) 000-00-00"

# SMTP (for password reset emails)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"       # true for port 465
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM_EMAIL="no-reply@example.com"
SMTP_FROM_NAME="ai-sub"

# Logging (pino — JSON in production, pretty in dev)
# LOG_LEVEL=debug
# LOG_PRETTY=true
# LOG_PRISMA_QUERIES=true

# Cron (unread message emails after 10 minutes)
CRON_SECRET="your-cron-secret"

# Telegram bot (optional — create via @BotFather): catalog, checkout, buyer & staff support
TELEGRAM_SELL_BOT_TOKEN=""
# Public @username for buyer links on the website (e.g. MyShopBot)
TELEGRAM_BOT_USERNAME=""
# Comma-separated Telegram user IDs with staff access (legacy fallback; prefer linking in admin panel)
TELEGRAM_SUPPORT_USER_IDS=""
# Shared secret for webhook requests (A-Z, a-z, 0-9, _, - only; e.g. openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=""
# Auto-register webhooks when the production server starts (default: on in production)
# TELEGRAM_AUTO_WEBHOOKS=true
# Optional pepper for Telegram email verification codes (defaults to BETTER_AUTH_SECRET)
# TELEGRAM_EMAIL_VERIFICATION_SECRET=""
