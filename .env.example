BETTER_AUTH_SECRET="your-better-auth-secret" # at least 32 characters
BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app

# Admin panel (comma-separated emails allowed to access /admin)
ADMIN_EMAILS="admin@example.com"

# Dev seed user (prisma/seed.ts) — must match ADMIN_EMAILS
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin12345"
ADMIN_NAME="Администратор"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# YooKassa (payment provider)
YOOKASSA_SHOP_ID="your-shop-id"
YOOKASSA_SECRET_KEY="your-secret-key"

# SMTP (for password reset emails)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"       # true for port 465
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM_EMAIL="no-reply@example.com"
SMTP_FROM_NAME="AI Sub Sell"
